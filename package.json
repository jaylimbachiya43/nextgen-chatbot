{
  "name": "nextgen-chatbot",
  "version": "1.0.10",
  "description": "A powerful, customizable chatbot component for Next.js applications that integrates with Google's Gemini AI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && mkdir -p dist/styles && cp src/styles/chat.css dist/styles/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "chatbot",
    "nextjs",
    "react",
    "gemini",
    "ai",
    "chat",
    "assistant",
    "typescript",
    "component"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "react": "^18.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0 <100.0.0",
    "react": "^18.0.0"
  },
  "files": [
    "dist",
    "dist/styles/chat.css",
    "README.md"
  ],
  "author": "Jay Limbachiya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/nextgen-chatbot.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/nextgen-chatbot/issues"
  },
  "homepage": "https://github.com/yourusername/nextgen-chatbot#readme",
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.8.3"
  }
}
